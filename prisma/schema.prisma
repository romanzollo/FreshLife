// Prisma schema for OzonFresh — доставка продуктов питания
//
// СТРАТЕГИЯ БАЗЫ ДАННЫХ:
//   Локальная разработка  → SQLite (файл prisma/dev.db, не нужен интернет)
//   Продакшен (Vercel)    → Turso (облачный libSQL, совместим с SQLite)
//
// Turso использует протокол libSQL — это форк SQLite с поддержкой сети.
// Prisma подключается к нему через driverAdapters (previewFeature).
// Схема данных одинакова для обоих режимов — менять модели не нужно.

generator client {
  provider        = "prisma-client-js"
  // driverAdapters — экспериментальная функция Prisma, нужна для Turso.
  // Без неё Prisma не умеет использовать внешние драйверы (@prisma/adapter-libsql).
  // В Prisma 5.x это preview feature; в будущих версиях станет стабильной.
  previewFeatures = ["driverAdapters"]
}

datasource db {
  // "sqlite" подходит и для локального SQLite, и для Turso (libSQL — это SQLite-совместимый протокол).
  // Менять провайдер на "postgresql" или другой НЕ нужно.
  provider = "sqlite"
  // DATABASE_URL берётся из переменной окружения:
  //   Локально (.env):  file:./dev.db
  //   Vercel (env vars): libsql://your-db.turso.io?authToken=...
  url      = env("DATABASE_URL")
}

// Категория товара, например "Фрукты и овощи" или "Молочные продукты".
// Вынесена в отдельную сущность, чтобы удобно фильтровать и переиспользовать.
model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  products  Product[]
}

// Товар в каталоге.
// Здесь хранятся только данные самого товара, без информации о заказах.
model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  imageUrl    String?

  // Связь с категорией: один товар принадлежит одной категории.
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Остатки и единицы измерения помогают красивее отображать товары на витрине.
  inStock     Int      @default(100)
  unit        String   @default("шт") // шт, кг, л

  createdAt   DateTime @default(now())
  orderItems  OrderItem[]

  // Индекс по категории и дате создания — самые частые сценарии выборки на витрине.
  @@index([categoryId])
  @@index([createdAt])
}

// Заказ пользователя (упрощённый вариант без аутентификации).
// В реальном проекте сюда добавляется связь с пользователем.
model Order {
  id           String      @id @default(cuid())
  customerName String
  address      String
  phone        String

  // Статус заказа хранится строкой для простоты.
  // При развитии проекта можно вынести в enum.
  status      String      @default("pending") // pending, confirmed, delivered, cancelled
  totalAmount Float
  createdAt   DateTime    @default(now())
  items       OrderItem[]

  // Индекс по дате — удобно для сортировки "сначала новые".
  @@index([createdAt])
}

// Позиция в заказе: конкретный товар с количеством и ценой на момент покупки.
model OrderItem {
  id        String  @id @default(cuid())

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity  Int
  price     Float

  // Часто ищем все позиции по заказу.
  @@index([orderId])
}
