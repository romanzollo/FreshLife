{
    "name": "ozon-fresh",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 4000",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "db:push": "prisma db push",
        "db:push:turso": "ts-node -P tsconfig.scripts.json scripts/push-schema-to-turso.ts",
        "db:seed:turso": "ts-node -P tsconfig.scripts.json scripts/seed-turso.ts",
        "db:seed": "ts-node -P tsconfig.seed.json prisma/seed.ts",
        "db:reset": "prisma db push --force-reset && npm run db:seed",
        "bulk-upload": "ts-node -P tsconfig.scripts.json scripts/bulk-upload.ts",
        "postinstall": "prisma generate"
    },
    "prisma": {
        "seed": "ts-node -P tsconfig.seed.json prisma/seed.ts"
    },
    "dependencies": {
        "@libsql/client": "^0.8.1",
        "@prisma/adapter-libsql": "^5.22.0",
        "@prisma/client": "^5.22.0",
        "next": "16.1.6",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hot-toast": "^2.6.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "prisma": "^5.22.0",
        "tailwindcss": "^4",
        "ts-node": "^10.9.2",
        "typescript": "^5"
    }
}
